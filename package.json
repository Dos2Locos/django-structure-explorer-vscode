{
  "name": "django-structure-explorer",
  "displayName": "Django Structure Explorer",
  "description": "PyCharm-style Django project structure explorer for VSCode",
  "version": "1.7.0",
  "publisher": "Dos2Locos",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dos2Locos/django-structure-explorer-vscode.git"
  },
  "engines": {
    "vscode": "^1.73.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:manage.py",
    "onView:djangoStructureExplorer",
    "onView:django-explorer"
  ],
  "main": "./out/extension.js",
  "icon": "resources/django.png",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "djangoStructureExplorer.sortOrder": {
          "type": "string",
          "default": "alphabetical",
          "enum": [
            "alphabetical",
            "alphabeticalDesc",
            "codeOrder"
          ],
          "enumDescriptions": [
            "%config.sortOrder.alphabetical%",
            "%config.sortOrder.alphabeticalDesc%",
            "%config.sortOrder.codeOrder%"
          ],
          "description": "%config.sortOrder.description%"
        },
        "djangoStructureExplorer.pythonPath": {
          "type": "string",
          "default": "python",
          "scope": "machine",
          "description": "%config.pythonPath.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "django-explorer",
          "title": "%viewContainer.title%",
          "icon": "resources/activity-icon.svg"
        }
      ]
    },
    "views": {
      "django-explorer": [
        {
          "id": "djangoStructureExplorer",
          "name": "%view.name%"
        }
      ]
    },
    "languages": [
      {
        "id": "python",
        "extensions": [
          ".py"
        ]
      }
    ],
    "commands": [
      {
        "command": "djangoStructureExplorer.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "djangoStructureExplorer.openFile",
        "title": "%command.openFile.title%"
      },
      {
        "command": "djangoStructureExplorer.runManageCommand",
        "title": "%command.runManageCommand.title%",
        "icon": "$(run)"
      },
      {
        "command": "djangoStructureExplorer.runCustomCommand",
        "title": "%command.runCustomCommand.title%",
        "icon": "$(run)"
      },
      {
        "command": "djangoStructureExplorer.filter",
        "title": "%command.filter.title%",
        "icon": "$(filter)"
      },
      {
        "command": "djangoStructureExplorer.clearFilter",
        "title": "%command.clearFilter.title%",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "djangoStructureExplorer.runManageCommand",
          "when": "view == djangoStructureExplorer",
          "group": "navigation@1"
        },
        {
          "command": "djangoStructureExplorer.filter",
          "when": "view == djangoStructureExplorer",
          "group": "navigation@2"
        },
        {
          "command": "djangoStructureExplorer.clearFilter",
          "when": "view == djangoStructureExplorer && djangoStructureExplorer.filterActive",
          "group": "navigation@3"
        },
        {
          "command": "djangoStructureExplorer.refresh",
          "when": "view == djangoStructureExplorer",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "djangoStructureExplorer.runCustomCommand",
          "when": "view == djangoStructureExplorer && viewItem == command",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "djangoStructureExplorer.runCustomCommand",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "mocha",
    "commit": "cz",
    "release": "commit-and-tag-version --skip.tag",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.2",
    "@types/node": "14.x",
    "@types/vscode": "^1.73.0",
    "@typescript-eslint/eslint-plugin": "^4.26.0",
    "@typescript-eslint/parser": "^4.26.0",
    "commit-and-tag-version": "^12.7.3",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^7.27.0",
    "glob": "^7.1.7",
    "husky": "^9.1.7",
    "mocha": "^11.1.0",
    "typescript": "^4.3.2"
  },
  "dependencies": {
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.20.8"
  }
}
