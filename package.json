{
  "name": "django-structure-explorer",
  "displayName": "Django Structure Explorer",
  "description": "PyCharm-style Django project structure explorer for VSCode",
  "version": "1.3.0",
  "publisher": "Dos2Locos",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dos2Locos/django-structure-explorer-vscode.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:manage.py",
    "onView:djangoStructureExplorer",
    "onView:django-explorer"
  ],
  "main": "./out/extension.js",
  "icon": "resources/django.png",
  "contributes": {
    "configuration": {
      "title": "Django Structure Explorer",
      "properties": {
        "djangoStructureExplorer.sortOrder": {
          "type": "string",
          "default": "alphabetical",
          "enum": [
            "alphabetical",
            "alphabeticalDesc",
            "codeOrder"
          ],
          "enumDescriptions": [
            "Sort items alphabetically (A-Z)",
            "Sort items alphabetically (Z-A)",
            "Keep items in the order they appear in code"
          ],
          "description": "How to sort items in the tree view"
        },
        "djangoStructureExplorer.pythonPath": {
          "type": "string",
          "default": "python",
          "scope": "machine",
          "description": "Python interpreter used to run manage.py commands (e.g. python, python3, or a virtualenv path). Machine-scoped: cannot be overridden by workspace settings."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "django-explorer",
          "title": "Django Explorer",
          "icon": "resources/django.svg"
        }
      ]
    },
    "views": {
      "django-explorer": [
        {
          "id": "djangoStructureExplorer",
          "name": "Django Explorer"
        }
      ]
    },
    "languages": [
      {
        "id": "python",
        "extensions": [
          ".py"
        ]
      }
    ],
    "commands": [
      {
        "command": "djangoStructureExplorer.refresh",
        "title": "Refresh Django Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "djangoStructureExplorer.openFile",
        "title": "Open File"
      },
      {
        "command": "djangoStructureExplorer.runManageCommand",
        "title": "Django: Run manage.py Command",
        "icon": "$(run)"
      },
      {
        "command": "djangoStructureExplorer.runCustomCommand",
        "title": "Django: Run This Management Command",
        "icon": "$(run)"
      },
      {
        "command": "djangoStructureExplorer.filter",
        "title": "Django: Filter Explorer",
        "icon": "$(filter)"
      },
      {
        "command": "djangoStructureExplorer.clearFilter",
        "title": "Django: Clear Explorer Filter",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "djangoStructureExplorer.runManageCommand",
          "when": "view == djangoStructureExplorer",
          "group": "navigation@1"
        },
        {
          "command": "djangoStructureExplorer.filter",
          "when": "view == djangoStructureExplorer",
          "group": "navigation@2"
        },
        {
          "command": "djangoStructureExplorer.clearFilter",
          "when": "view == djangoStructureExplorer && djangoStructureExplorer.filterActive",
          "group": "navigation@3"
        },
        {
          "command": "djangoStructureExplorer.refresh",
          "when": "view == djangoStructureExplorer",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "djangoStructureExplorer.runCustomCommand",
          "when": "view == djangoStructureExplorer && viewItem == command",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "djangoStructureExplorer.runCustomCommand",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "mocha"
  },
  "devDependencies": {
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.2",
    "@types/node": "14.x",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^4.26.0",
    "@typescript-eslint/parser": "^4.26.0",
    "eslint": "^7.27.0",
    "glob": "^7.1.7",
    "mocha": "^11.1.0",
    "typescript": "^4.3.2"
  },
  "dependencies": {
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.20.8"
  }
}
